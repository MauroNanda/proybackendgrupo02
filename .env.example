# ===== Base de datos (Neon.tech / Postgres) =====
# Cadena de conexión completa con SSL. REQUERIDA.
DATABASE_URL=postgres://usuario:password@host/db?sslmode=require

# ===== Servidor =====
PORT=3000
# Origen permitido para CORS (frontend Angular).
CORS_ORIGIN=http://localhost:4200
# URL base del frontend (para redirigir tras el callback de Google OAuth).
FRONTEND_URL=http://localhost:4200
# development | production
NODE_ENV=development

# ===== Autenticación JWT =====
# Obligatoria en producción; en desarrollo es opcional (hay un secreto de respaldo).
# Generar uno fuerte, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
# Tiempo de expiración del token (opcional, por defecto 24h).
JWT_EXPIRES_IN=24h

# ===== Integraciones =====
# API key de Resend para envío de emails (opcional; si falta, se simula por consola).
# También se usa para enviar el código 2FA por email.
RESEND_API_KEY=

# Google OAuth 2.0 (login con Google). Crear credenciales de tipo "Aplicación web"
# en Google Cloud Console y autorizar el redirect URI de abajo.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Debe coincidir EXACTO con un "URI de redireccionamiento autorizado" en la consola.
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
