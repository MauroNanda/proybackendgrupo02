# ===== Base de datos (Neon.tech / Postgres) =====
# Cadena de conexión completa con SSL. REQUERIDA.
DATABASE_URL=postgres://usuario:password@host/db?sslmode=require

# ===== Servidor =====
PORT=3000
# Origen permitido para CORS (frontend Angular).
CORS_ORIGIN=http://localhost:4200
# development | production
NODE_ENV=development

# ===== Autenticación JWT =====
# Obligatoria en producción; en desarrollo es opcional (hay un secreto de respaldo).
# Generar uno fuerte, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
# Tiempo de expiración del token (opcional, por defecto 24h).
JWT_EXPIRES_IN=24h

# ===== Integraciones =====
# API key de Resend para envío de emails (opcional; si falta, se simula por consola).
RESEND_API_KEY=

# Telegram — difusión de eventos en un canal (opcional; si falta, se desactiva).
# TELEGRAM_BOT_TOKEN: token que da @BotFather al crear el bot.
# TELEGRAM_CHANNEL_ID: id/@usuario del canal donde el bot (admin) publica.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Discord — difusión de eventos publicados en un canal del servidor (opcional;
# si falta el token, el bot no se conecta y la difusión queda desactivada).
# DISCORD_BOT_TOKEN: Developer Portal → tu app → Bot → Reset Token.
# DISCORD_CHANNEL_ID: click derecho sobre el canal → Copiar ID de canal
#   (requiere activar el Modo desarrollador en Ajustes de usuario → Avanzado).
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
