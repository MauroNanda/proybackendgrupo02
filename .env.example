# ===== Base de datos (Neon.tech — Postgres) =====
# URL completa de conexión. Incluir ?sslmode=require al final (obligatorio para Neon).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# ===== Servidor =====
PORT=3000
NODE_ENV=development

# Origen permitido por CORS (frontend Angular en dev).
# En producción reemplazar por la URL del frontend desplegado.
CORS_ORIGIN=http://localhost:4200

# ===== JWT =====
# Clave para firmar tokens. Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambiar-en-produccion-generar-clave-segura"
JWT_EXPIRES_IN=7d

# ===== Telegram Bot (Fase 3) =====
# Se obtiene hablándole a @BotFather en Telegram.
TELEGRAM_BOT_TOKEN=""

# ===== Discord Bot (Fase 3) =====
DISCORD_BOT_TOKEN=""
DISCORD_CHANNEL_ID=""

# ===== Google OAuth 2.0 (Fase 3) =====
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/auth/google/callback"

# ===== Resend (Email transaccional, Fase 1 dominio Notificaciones) =====
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Convoca <noreply@convoca.app>"

# ===== Web Push (Fase 3) =====
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@convoca.app"
