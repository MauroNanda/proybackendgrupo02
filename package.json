{
  "name": "convoca-backend",
  "version": "0.1.0",
  "description": "Backend de Convoca — Sistema de Gestión de Eventos Universitarios (Grupo G02, UNJu).",
  "main": "app.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo:all",
    "lint": "eslint .",
    "test": "echo \"No tests yet\" && exit 0",
    "prepare": "husky"
  },
  "keywords": [
    "convoca",
    "eventos",
    "unju",
    "express",
    "sequelize",
    "postgres"
  ],
  "author": "Grupo G02 — UNJu",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "resend": "^6.16.0",
    "sequelize": "^6.37.5",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2"
  },
  "lint-staged": {
    "*.js": "eslint --fix"
  }
